# Base resume path (relative to project root or absolute)
BASE_RESUME_PATH=data/base_resume/resume.docx

# Directories for context files and per-job output
CONTEXT_DIR=data/context/
JOBS_DIR=data/jobs/

# DeepSeek API (get key from https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=

# Privacy: redact likely PII before sending prompts to DeepSeek
REDACT_PII_FOR_DEEPSEEK=true

# Ollama (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_API_BASE=http://localhost:11434/api
OLLAMA_MODEL=llama3:8b

# Ollama-only defaults
USE_DEEPSEEK=false
# DEFAULT_MODEL_SEQUENCE=["ollama:qwen3:8b","ollama:qwen3:8b","ollama:qwen3:8b","ollama:qwen3:8b"]
# MODELS_CATALOG_PATH=data/models_catalog.json

# Installed models registry + cache
# MODEL_REGISTRY_PATH=data/models_registry.json
# HUB_CACHE_DIR=data/hub_cache/
#
# Optional: Hugging Face token (recommended for large GGUF downloads to avoid rate limits)
# Get one from https://huggingface.co/settings/tokens
HF_TOKEN=

# llama.cpp defaults for installed GGUF models
# LLAMACPP_N_CTX=8192
# LLAMACPP_N_GPU_LAYERS=-1
# LLAMACPP_N_THREADS=0
# LLAMACPP_TEMPERATURE=0.3

# Context window and behaviour
MAX_CONTEXT_TOKENS=32000
QUALITY_OVER_SPEED=true

# Humanize step: after final polish, rewrite for human-like rhythm (reduces AI-detection flags). Set false to disable.
# HUMANIZE_STEP=true
# HUMANIZE_TEMPERATURE=0.6

# Optional: token counter warning for DeepSeek free tier (not implemented yet)
# DEEPSEEK_WARN_TOKENS=50000
